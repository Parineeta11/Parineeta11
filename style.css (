body{
font-family: Arial;
background: linear-gradient(to right,#ff9966,#ff5e62);
color:white;
margin:0;
}

header{
background:#222;
padding:20px;
text-align:center;
}

nav a{
color:white;
margin:10px;
text-decoration:none;
font-size:18px;
}

section{
padding:30px;
background:rgba(0,0,0,0.3);
margin:20px;
border-radius:10px;
}

h1,h2,h3{
color:#ffe600;
}

button{
background:#00ffcc;
padding:10px 20px;
border:none;
font-size:16px;
cursor:pointer;
}
